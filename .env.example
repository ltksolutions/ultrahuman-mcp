# Ultrahuman MCP Server – Environment Variables
# Copy this file to .env and fill in your values

# Your Ultrahuman API auth token (get from Ultrahuman support)
ULTRAHUMAN_AUTH_TOKEN=your_token_here

# Your Ultrahuman account email
ULTRAHUMAN_USER_EMAIL=your_email@example.com

# Server port (default: 3000)
PORT=3000
